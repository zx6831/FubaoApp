{
  "name": "@fubao/api",
  "version": "0.1.0",
  "private": true,
  "description": "福豹 App 可部署调试后端",
  "scripts": {
    "build": "npm run prisma:generate && nest build && node -e \"require('node:fs').accessSync('dist/main.js')\"",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate deploy",
    "start": "node dist/main.js",
    "start:prod": "npm run prisma:migrate && node dist/main.js",
    "start:dev": "nest start --watch",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "verify": "npm run prisma:validate && npm run prisma:generate && npm test && npm run build"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/swagger": "^11.2.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "joi": "^18.2.3",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/testing": "^11.1.6",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.18.6",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "jest": "^30.1.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
